# ══════════════════════════════════════════════════════════════
#  Achadinhos do Momento — .env.example  (v6 — Fase 1/2/3)
#  Copie para .env e preencha os valores reais.
#  NUNCA commite o .env com valores reais!
# ══════════════════════════════════════════════════════════════

# ── Backend ──────────────────────────────────────────────────
# [PG-1] PostgreSQL — obrigatório (ex: Render Postgres Free)
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://achadinhos:senha@hostname:5432/achadinhos_db

ADMIN_SECRET=troque_por_um_secret_forte_aqui

# CORS — origin do frontend (sem barra final)
FRONTEND_ORIGIN=http://localhost:5500

# ── [IMG-URL] Imagens ─────────────────────────────────────────
# Não há mais variáveis de serviço de imagem (ImgBB removido).
# Basta colar a URL da imagem direto no formulário Admin.
# MAX_IMAGE_MB foi removido — não há mais validação de tamanho.

# ── Meta / Instagram Webhook ─────────────────────────────────
WEBHOOK_VERIFY_TOKEN=seu_token_de_verificacao
META_APP_SECRET=seu_app_secret_da_meta
PAGE_ACCESS_TOKEN=seu_page_access_token

# ── Bot Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHANNEL_ID=@seu_canal_ou_-100xxxxxxxxx

# [HC-3] Chat de admin para receber alertas críticos do bot
# Pode ser seu chat pessoal com o bot (use seu Telegram user ID)
# ou um grupo privado. Se não configurado, usa TELEGRAM_CHANNEL_ID.
# Como descobrir seu ID: envie /start para @userinfobot no Telegram.
ADMIN_TELEGRAM_CHAT_ID=seu_user_id_ou_group_id

API_BASE_URL=http://localhost:8000

# ── Video Organizer ──────────────────────────────────────────
VIDEO_OUTPUT_DIR=./organized
QUEUE_CSV=./queue.csv

# ── Shopee Afiliados ─────────────────────────────────────────
SHOPEE_APP_ID=123456
SHOPEE_APP_SECRET=abcdef1234567890abcdef
SHOPEE_SUB_ID=achadinhos

# ── Render (produção) ────────────────────────────────────────
PUBLIC_API_URL=https://achadinhos-api.onrender.com
# ── TTS ──────────────────────────────────────────────────────
TTS_ENGINE=fish

# Kokoro
KOKORO_SCRIPT=/home/SEU_USUARIO/tts_batch.py
KOKORO_VENV=/home/SEU_USUARIO/tts-env/bin/python

# Fish Speech (alternativa)
FISH_SCRIPT=/home/SEU_USUARIO/fish-speech/fish_batch.py
FISH_VENV=/home/SEU_USUARIO/fish-speech/venv/bin/python
FISH_DIR=/home/SEU_USUARIO/fish-speech

TTS_TIMEOUT=120

# Claude API (para geração de roteiro)
ANTHROPIC_API_KEY=sua_chave_aqui

VIDEO_OOM_THRESHOLD=3
TTS_FAIL_THRESHOLD=3
