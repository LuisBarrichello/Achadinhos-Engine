# ══════════════════════════════════════════════════════════════
#  Achadinhos do Momento — .env.example  (v8 — melhorias)
#  Copie para .env e preencha os valores reais.
#  NUNCA commite o .env com valores reais!
# ══════════════════════════════════════════════════════════════

# ── Backend ──────────────────────────────────────────────────
DATABASE_URL=postgresql://achadinhos:senha@hostname:5432/achadinhos_db
ADMIN_SECRET=troque_por_um_secret_forte_aqui
FRONTEND_ORIGIN=https://seu-projeto.vercel.app

# ── Meta / Instagram Webhook ─────────────────────────────────
WEBHOOK_VERIFY_TOKEN=seu_token_de_verificacao
META_APP_SECRET=seu_app_secret_da_meta
PAGE_ACCESS_TOKEN=seu_page_access_token

# ── Bot Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=seu_bot_token_aqui
TELEGRAM_CHANNEL_ID=@seu_canal_ou_-100xxxxxxxxx
ADMIN_TELEGRAM_CHAT_ID=seu_user_id_ou_group_id

API_BASE_URL=https://achadinhos-api.onrender.com

# ── Garimpeiro — ciclos ──────────────────────────────────────
POLL_INTERVAL_MIN=30
MIN_DISCOUNT_PCT=20
DEALS_PER_CYCLE=5
HTTP_TIMEOUT=20.0

# ── [QF] Filtros de qualidade ────────────────────────────────
# Produtos abaixo destes valores são descartados antes de qualquer envio
MIN_RATING=4.5      # rating mínimo do produto (0 = desabilitado)
MIN_SOLD=1000       # vendas mínimas do produto (0 = desabilitado)

# ── [RP] Repost automático ───────────────────────────────────
# Dias da semana: 0=seg, 1=ter, 2=qua, 3=qui, 4=sex, 5=sáb, 6=dom
REPOST_DAYS=4,5,6   # sexta, sábado, domingo
REPOST_MAX=3        # máx de reposts por ciclo
REPOST_MIN_CLICKS=5 # cliques mínimos para entrar no repost

# ── [TTL] TTL do processed_deals.json ───────────────────────
# Após este período, produtos podem reaparecer no feed
DEAL_TTL_DAYS=14

# ── [BP] Detecção de bug de preço ────────────────────────────
# Desconto acima deste % dispara alerta separado no Telegram
PRICE_BUG_THRESHOLD=60

# ── [DQ-1] Fila de DMs ──────────────────────────────────────
DM_POLL_INTERVAL_SEC=60
DM_MAX_RETRIES=3

# ── Video Organizer ──────────────────────────────────────────
VIDEO_OUTPUT_DIR=./organized
QUEUE_CSV=./queue.csv

# ── Shopee Afiliados ─────────────────────────────────────────
SHOPEE_APP_ID=123456
SHOPEE_APP_SECRET=abcdef1234567890abcdef
SHOPEE_SUB_ID=achadinhos

# ── TTS ──────────────────────────────────────────────────────
TTS_ENGINE=fish
KOKORO_SCRIPT=/home/SEU_USUARIO/tts_batch.py
KOKORO_VENV=/home/SEU_USUARIO/tts-env/bin/python
FISH_SCRIPT=/home/SEU_USUARIO/fish-speech/fish_batch.py
FISH_VENV=/home/SEU_USUARIO/fish-speech/venv/bin/python
FISH_DIR=/home/SEU_USUARIO/fish-speech
TTS_TIMEOUT=120

# ── Claude API ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sua_chave_aqui

# ── Circuit breakers ─────────────────────────────────────────
VIDEO_OOM_THRESHOLD=3
TTS_FAIL_THRESHOLD=3
